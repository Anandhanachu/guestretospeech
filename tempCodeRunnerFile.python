import cv2
import numpy as np
image = cv2.imread("unni.jpg")
(h, w) = image.shape[ :2]

angle = 30
scale = 1.0
center = (w // 2,h // 2)

M = cv2.getRotationMatrix2D(center, angle, scale)
rotated = cv2.warpAffine(image, M, (w,h))
cv2.imshow("Rotated image", rotated)
cv2.waitKey(0)
cv2.destroyAllwindows()