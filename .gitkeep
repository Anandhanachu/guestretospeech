import serial
import pyttsx3
import time

# -----------------------------
# SERIAL SETTINGS
# -----------------------------
PORT = 'COM7'
BAUD = 9600

# -----------------------------
# GESTURE MEMORY
# -----------------------------
lastGesture = None
lastTime = 0
delayTime = 2


# -----------------------------
# SPEAK FUNCTION
# -----------------------------
def speak(text):

    print("Speaking:", text)

    engine = pyttsx3.init()

    voices = engine.getProperty('voices')
    engine.setProperty('voice', voices[1].id)   # female voice

    engine.setProperty('rate',150)
    engine.setProperty('volume',3.0)

    engine.say(text)
    engine.runAndWait()
    engine.stop()


# -----------------------------
# GESTURE DETECTION
# -----------------------------
def detectGesture(f1,f2,f3,f4):

    if f1 < 400 and f2 < 400 and f3 < 400 and f4 > 50:
        return "Hello"
    
    elif f1 < 400 and f2 < 400 and f3 >50 and f4 < 400 :
        return "Goodbye"
    elif f1 < 400 and f2 > 80 and f3 <400 and f4 < 400 :
        return "thank you"
    elif f1 > 80 and f2 < 400 and f3 <400 and f4 < 400 :
        return "I love you"

    else:
        return None


# -----------------------------
# CONNECT TO ARDUINO
# -----------------------------
print("Connecting to Arduino...")

ser = serial.Serial(PORT, BAUD)
time.sleep(2)

print("System Started")
print("Listening...\n")


# -----------------------------
# MAIN LOOP
# -----------------------------
while True:

    if ser.in_waiting > 0:

        try:

            data = ser.readline().decode().strip()
            parts = data.split()

            if len(parts) == 4:

                f1 = int(parts[0])
                f2 = int(parts[1])
                f3 = int(parts[2])
                f4 = int(parts[3])

                print("Flex:", f1, f2, f3, f4)

                gesture = detectGesture(f1,f2,f3,f4)

                if gesture:

                    currentTime = time.time()

                    if gesture != lastGesture or currentTime-lastTime > delayTime:

                        speak(gesture)

                        lastGesture = gesture
                        lastTime = currentTime

        except:
            pass